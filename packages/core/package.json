{
  "name": "@avoxjs/core",
  "version": "0.0.12",
  "description": "Laravel-like framework for Node.js on Fastify + Drizzle",
  "license": "MIT",
  "author": "riteshintro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riteshintro/RDX.js.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/riteshintro/RDX.js#readme",
  "bugs": "https://github.com/riteshintro/RDX.js/issues",
  "keywords": [
    "framework",
    "laravel",
    "fastify",
    "drizzle",
    "typescript",
    "avox",
    "nodejs",
    "api"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./container": {
      "types": "./dist/container/index.d.ts",
      "import": "./dist/container/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js"
    },
    "./routing": {
      "types": "./dist/routing/index.d.ts",
      "import": "./dist/routing/index.js"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler/index.d.ts",
      "import": "./dist/scheduler/index.js"
    },
    "./mail": {
      "types": "./dist/mail/index.d.ts",
      "import": "./dist/mail/index.js"
    },
    "./uploads": {
      "types": "./dist/uploads/index.d.ts",
      "import": "./dist/uploads/index.js"
    },
    "./exceptions": {
      "types": "./dist/exceptions/index.d.ts",
      "import": "./dist/exceptions/index.js"
    },
    "./support": {
      "types": "./dist/support/index.d.ts",
      "import": "./dist/support/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/multipart": "^9.0.1",
    "better-auth": "^1.6.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "handlebars": "^4.7.8",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "@swc/core": "^1.9.3",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
