    "tinyglobby": "^0.2.10",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
