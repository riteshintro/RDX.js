{
  "name": "@rdx/cli",
  "version": "0.0.1",
  "description": "rdx framework command-line interface",
  "type": "module",
  "bin": {
    "rdx": "./dist/bin.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
